rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles — anyone authenticated can read; only owner can write
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Workspaces — only the owner can access their workspace
    match /workspaces/{workspaceId} {
      allow read, write: if request.auth != null && request.auth.uid == workspaceId;
    }

    // Projects —
    //   owner (workspaceId == uid): full control
    //   non-owner members (uid in memberIds): can read; can update if admin/writer
    match /projects/{projectId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.workspaceId ||
        request.auth.uid in resource.data.memberIds
      );
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.workspaceId;
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.workspaceId;
      // Owner can always update; members can update if they have admin/writer role
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.workspaceId ||
        (request.auth.uid in resource.data.memberIds &&
          resource.data.members[request.auth.uid].role in ['admin', 'writer'])
      );
    }

    // Tasks — any authenticated member of the project can read/write
    // (role enforcement happens client-side; server rules keep data private)
    match /tasks/{taskId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
